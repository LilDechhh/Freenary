<file path="back/prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String        
  name         String
  role         String        @default("MEMBER")
  createdAt    DateTime      @default(now())
  
  assets       Asset[]       
  transactions Transaction[] 
  wallets      Wallet[]      // <-- NOUVEAU : Un utilisateur possède plusieurs wallets
  historicalData HistoricalData[]
}

model Wallet {
  id          String   @id @default(uuid())
  name        String   // Ex: "Ledger BTC", "Solflare Principal"
  blockchain  String   // Ex: "solana", "ethereum", "bitcoin"
  address     String   // L'adresse publique (Ex: 5X... pour Solflare)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id              String        @id @default(uuid())
  category        String        
  name            String        
  quantity        Float?              
  totalValue      Float         
  gainLoss        Float?        
  gainLossPercent Float?        
  
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  historicalData  HistoricalData[] 
  transactions    Transaction[]    
  
  updatedAt       DateTime      @updatedAt
}

model HistoricalData {
  id        String   @id @default(uuid())
  date      String   
  value     Float    
  
  assetId   String?  
  asset     Asset?   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // --- LES DEUX LIGNES À AJOUTER SONT ICI ---
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}

model Transaction {
  id        String   @id @default(uuid())
  date      DateTime 
  category  String   
  type      String   
  amount    Float    
  quantity  Float?   
  price     Float?   
  
  assetId   String   
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
</file>

<file path="back/src/wealth.controller.ts">
import {
  Controller,
  Get,
  Param,
  Post,
  Body,
  UseGuards,
  Request,
  UnauthorizedException,
} from '@nestjs/common';
import { WealthService } from './wealth.service';
import { AuthGuard } from './auth.guard';
import { CreateTransactionDto } from './create-transaction.dto';

@UseGuards(AuthGuard)
@Controller('wealth')
export class WealthController {
  // On injecte le service ici
  constructor(private readonly wealthService: WealthService) {}

  @Get()
  async getWealth(@Request() req: any) {
    // On récupère l'ID sécurisé depuis le token décodé par l'AuthGuard
    const userId = req.user?.sub || req.user?.id;
    if (!userId)
      throw new UnauthorizedException(
        'Utilisateur non identifié dans le token',
      );

    return this.wealthService.getWealthData(userId);
  }

  @Get(':category')
  async getCategoryDetails(
    @Param('category') category: string,
    @Request() req: any,
  ) {
    const userId = req.user?.sub || req.user?.id;

    return this.wealthService.getCategoryDetailsData(category, userId);
  }

  @Post('transaction')
  async addTransaction(
    @Body() body: CreateTransactionDto, // 🛡️ Fini le "any", place au DTO !
    @Request() req: any,
  ) {
    const userId = req.user?.sub || req.user?.id;
    return this.wealthService.addTransactionData(body, userId);
  }

  @Post('wallet')
  async addWallet(
    @Body() body: { name: string; blockchain: string; address: string },
    @Request() req: any,
  ) {
    const userId = req.user?.sub || req.user?.id;

    return this.wealthService.addWalletData(body, userId);
  }
}
</file>

